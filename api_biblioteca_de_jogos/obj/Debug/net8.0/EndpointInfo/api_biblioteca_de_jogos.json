{
  "openapi": "3.0.1",
  "info": {
    "title": "api_biblioteca_de_jogos",
    "version": "1.0"
  },
  "paths": {
    "/Jogo/cadastrar": {
      "post": {
        "tags": [
          "Jogo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JogoDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/JogoDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/JogoDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Jogo/editar": {
      "patch": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JogoDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/JogoDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/JogoDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Jogo/excluir": {
      "delete": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Jogo/id": {
      "get": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Jogo/listar": {
      "get": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "pagina",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "quantidade",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Jogo/listar/categoria": {
      "get": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "categoria",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/ECategoria"
            }
          },
          {
            "name": "pagina",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "quantidade",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Jogo/listar/nota": {
      "get": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "nota",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "pagina",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "quantidade",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ECategoria": {
        "enum": [
          "jogando",
          "queroJogar",
          "zerado",
          "desistido"
        ],
        "type": "string"
      },
      "EModo": {
        "enum": [
          "singleplayer",
          "multiplayer"
        ],
        "type": "string"
      },
      "JogoDTO": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "nullable": true
          },
          "genero": {
            "type": "string",
            "nullable": true
          },
          "modo": {
            "$ref": "#/components/schemas/EModo"
          },
          "categoria": {
            "$ref": "#/components/schemas/ECategoria"
          },
          "possui": {
            "type": "boolean"
          },
          "nota": {
            "type": "integer",
            "format": "int32"
          },
          "comentario": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}